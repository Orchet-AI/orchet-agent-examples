# Weather Public Readonly OAuth app credentials. Register at the vendor's
# developer portal and set redirect_uri=https://api.orchet.ai/connections/callback.
#
# Confidential client. The secret is server-side only.
ORCHET_WEATHER_PUBLIC_READONLY_CLIENT_ID=
ORCHET_WEATHER_PUBLIC_READONLY_CLIENT_SECRET=

# Public base URL of this agent. Used inside the manifest so absolute
# URLs (openapi_url, health_url) resolve. Defaults to
# https://weather-public-readonly.orchet.ai if unset.
ORCHET_WEATHER_PUBLIC_READONLY_AGENT_BASE_URL=
