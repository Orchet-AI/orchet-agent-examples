{
  "name": "orchet-weather-public-readonly-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Orchet specialist agent: Weather Public Readonly. Get current public weather for a city without user authentication.",
  "scripts": {
    "dev": "next dev -p 3007",
    "build": "next build",
    "start": "next start -p 3007",
    "typecheck": "tsc --noEmit",
    "validate-manifest": "node scripts/validate-manifest.mjs",
    "e2e:submit": "node scripts/e2e-orchet-submit.mjs",
    "test": "npm run typecheck && npm run validate-manifest && node scripts/e2e-orchet-submit.mjs --validate-local"
  },
  "dependencies": {
    "@orchet/agent-sdk": "github:Orchet-AI/orchet-agent-sdk#1895252",
    "next": "16.2.6",
    "react": "^18",
    "react-dom": "^18",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "typescript": "^5.4.5"
  },
  "overrides": {
    "postcss": "^8.5.15"
  }
}
